# Copy to .env.local and fill in real values. Never commit .env.local.

# ---------- LP Agent (Premium) ----------
LPAGENT_API_KEY=
LPAGENT_BASE_URL=https://api.lpagent.io

# ---------- Supabase ----------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=

# ---------- Solana RPC ----------
HELIUS_DEVNET_RPC_URL=
SOLANA_CLUSTER=devnet

# ---------- Privy ----------
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# ---------- AI (OpenRouter) ----------
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# ---------- On-chain keys (paths, not values — files live under keypairs/, gitignored) ----------
ADMIN_KEYPAIR_PATH=./keypairs/admin.json
SCORING_ORACLE_KEYPAIR_PATH=./keypairs/scoring-oracle.json
PROTOCOL_FEE_VAULT_KEYPAIR_PATH=./keypairs/protocol-fee-vault.json
PROGRAM_KEYPAIR_PATH=./programs/lp-arena/target/deploy/lp_arena-keypair.json

# ---------- Deployment targets ----------
VERCEL_PROJECT_ID=
VPS_SSH_HOST=
